{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Disc-image specific extension over the binary manifest for GameCube, PS2, and PSP media.",
  "properties": {
    "image_manifest_sha256": {
      "type": "string"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "system": {
      "enum": [
        "gamecube",
        "ps2",
        "psp"
      ]
    },
    "track_layout": {
      "type": "array"
    }
  },
  "required": [
    "system",
    "image_manifest_sha256"
  ],
  "title": "ARC Emulator Disc Manifest",
  "type": "object"
}
